FROM debian:bookworm-slim

# 환경변수
ENV LC_ALL=C.UTF-8
ENV DEBIAN_FRONTEND=noninteractive
ENV ANTHROPIC_BASE_URL=http://ollama:11434
ENV ANTHROPIC_AUTH_TOKEN=ollama
ENV CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

# Node.js 22 설치
RUN apt-get update && \
    apt-get install -y curl git netcat-traditional && \
    curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    apt-get clean && rm -rf /var/lib/apt/lists/*

# Claude Code 설치
RUN npm install -g @anthropic-ai/claude-code

# uplexsoft 유저 생성 (UID 1000)
RUN groupadd -g 1000 uplexsoft && \
    useradd -m -u 1000 -g 1000 -s /bin/bash uplexsoft

# uplexsoft용 .claude 디렉토리 생성
RUN mkdir -p /home/uplexsoft/.claude

# alias 설정 (시스템 전체)
RUN echo "alias cc='claude --dangerously-skip-permissions'" >> /etc/bash.bashrc

# uplexsoft 홈 소유권 설정
RUN chown -R uplexsoft:uplexsoft /home/uplexsoft

# Ollama 연결 대기 스크립트
RUN cat > /usr/local/bin/wait-for-ollama.sh <<'SCRIPT'
#!/bin/bash
# settings.json 동적 생성 (OLLAMA_MODEL 환경변수 반영)
mkdir -p /home/uplexsoft/.claude
cat > /home/uplexsoft/.claude/settings.json <<JSON
{
  "model": "${OLLAMA_MODEL}",
  "env": {
    "ANTHROPIC_BASE_URL": "http://ollama:11434",
    "ANTHROPIC_AUTH_TOKEN": "ollama"
  }
}
JSON

# Ollama 호스트 해석 가능 여부 확인 (Docker Compose 네트워크 밖이면 스킵)
if getent hosts ollama >/dev/null 2>&1; then
  echo "Waiting for Ollama to be ready..."
  until nc -z ollama 11434; do
    echo "Ollama is unavailable - sleeping"
    sleep 2
  done
  echo "Ollama is up - starting Claude Code environment"
else
  echo "Ollama host not found - running without Ollama"
fi
exec "$@"
SCRIPT

RUN chmod +x /usr/local/bin/wait-for-ollama.sh

# 기본 유저 (변경 가능: docker exec -u root ... 로 root 접근 가능)
USER uplexsoft
WORKDIR /home/uplexsoft

ENTRYPOINT ["/usr/local/bin/wait-for-ollama.sh"]
CMD ["sleep", "infinity"]
